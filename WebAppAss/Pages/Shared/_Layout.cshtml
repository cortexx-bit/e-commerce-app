<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebAppAss</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebAppAss.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.5.0/font/bootstrap-icons.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 navbar-custom">
            <div class="container">
                <a class="navbar-brand" id="logo" asp-area="" asp-page="/Index">
                    <img src="~/images/logo.png" alt="WebAppAss Logo" style="height: 40px;">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center w-100">
                    <ul class="navbar-nav w-100 justify-content-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Hours&location">Hours & Location</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Discover">Discover</a>
                        </li>
                    </ul>
                </div>
                <div class="navbar-right">
                    <div class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-page="/Account/Login">
                            <i class="bi bi-person-circle" aria-hidden="true"></i>
                            <span>Sign up/Login</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-page="/Cart">
                            <i class="bi bi-cart" aria-hidden="true"></i>
                            <span class="sr-only">Cart</span>
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="social-media">
            <a href="https://www.facebook.com" aria-label="Facebook" target="_blank">
                <i class="bi bi-facebook"></i>
            </a>
            <a href="https://www.twitter.com" aria-label="Twitter" target="_blank">
                <i class="bi bi-twitter"></i>
            </a>
            <a href="https://www.instagram.com" aria-label="Instagram" target="_blank">
                <i class="bi bi-instagram"></i>
            </a>
        </div>
        <div class="copyright">
            &copy; 2024 - WebAppAss
        </div>
        <div class="links">
            <a asp-area="" asp-page="/Privacy">Privacy Policy</a>
            <a asp-area="" asp-page="/Contactus">Contact Us</a>
            <a asp-area="" asp-page="/About">About us</a>
            <a asp-area="" asp-page="/EmailSignup" class="btn btn-signup">Email signup</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

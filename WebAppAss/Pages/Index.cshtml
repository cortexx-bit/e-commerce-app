@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div id="indexCarousel" class="carousel slide" data-ride="carousel" data-interval="3000">
    <ol class="carousel-indicators">
        <li data-target="#indexCarousel" data-slide-to="0" class="active"></li>
        <li data-target="#indexCarousel" data-slide-to="1"></li>
        <li data-target="#indexCarousel" data-slide-to="2"></li>
        <li data-target="#indexCarousel" data-slide-to="3"></li>
    </ol>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/img/carousel-burger.jpg" class="d-block w-100" alt="Image 1" />
        </div>
        <div class="carousel-item">
            <img src="~/img/carousel-swiss-burger.jpg" class="d-block w-100" alt="Image 2" />
        </div>
        <div class="carousel-item">
            <img src="~/img/carousel-kitchen.jpg" class="d-block w-100" alt="Image 3" />
        </div>
        <div class="carousel-item">
            <img src="~/img/carousel-interior.jpg" class="d-block w-100" alt="Image 4" />
        </div>
    </div>
    <a class="carousel-control-prev" href="#indexCarousel" role="button" data-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="sr-only">Previous</span>
    </a>
    <a class="carousel-control-next" href="#indexCarousel" role="button" data-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="sr-only">Next</span>
    </a>
</div>
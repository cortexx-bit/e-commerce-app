@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<!-- Carousel displaying rotating images -->
<div id="indexCarousel" class="carousel slide" data-ride="carousel" data-interval="3000">
    <ol class="carousel-indicators">
        <li data-target="#indexCarousel" data-slide-to="0" class="active"></li>
        <li data-target="#indexCarousel" data-slide-to="1"></li>
        <li data-target="#indexCarousel" data-slide-to="2"></li>
        <li data-target="#indexCarousel" data-slide-to="3"></li>
    </ol>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/img/carousel-burger.jpg" class="d-block w-100" alt="Burger" />
        </div>
        <div class="carousel-item">
            <img src="~/img/carousel-swiss-burger.jpg" class="d-block w-100" alt="Swiss burger" />
        </div>
        <div class="carousel-item">
            <img src="~/img/carousel-kitchen.jpg" class="d-block w-100" alt="Sam&Ella's kitchen" />
        </div>
        <div class="carousel-item">
            <img src="~/img/carousel-interior.jpg" class="d-block w-100" alt="Sam&Ella's restaurant interior" />
        </div>
    </div>
    <a class="carousel-control-prev" href="#indexCarousel" role="button" data-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="sr-only">Previous</span>
    </a>
    <a class="carousel-control-next" href="#indexCarousel" role="button" data-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="sr-only">Next</span>
    </a>
</div>
<!-- Container for special items section with spacing -->
<div class="container mt-5">
    <h2 class="mb-4">Special Items</h2>
    <div class="food-container">
        @foreach (var item in Model.SpecialItems)
        {
            <div class="food-item">
                <a asp-page="/Menu/Burger/Details" asp-route-id="@item.Id">
                    @if (item.ImageData != null)
                    {
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(item.ImageData)" alt="@item.ImageDescription" class="food-image" />
                    }
                    else
                    {
                        <img src="/images/no-image.png" alt="No image available" class="food-image" />
                    }
                </a>
                <a asp-page="/Menu/Burger/Details" asp-route-id="@item.Id">
                    <h3>@item.Name</h3>
                </a>
                <p class="description">@item.Description</p>
                <div class="food-footer">
                    <span class="price">@item.Price.ToString("C")</span>
                </div>
            </div>
        }
    </div>
</div>
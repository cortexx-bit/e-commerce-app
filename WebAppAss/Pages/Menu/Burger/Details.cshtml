@page "{name}"
@model WebAppAss.Pages.Menu.Burger.DetailsModel

@{
    ViewData["Title"] = "Burger Details";
}

<div class="container mt-5">
    <div class="row">
        <!-- Left Column: Big Image -->
        <div class="col-md-6">
            @if (Model.Burger.ImageData != null)
            {
                <img src="data:image;base64,@Convert.ToBase64String(Model.Burger.ImageData)"
                     alt="@Model.Burger.ImageDescription" class="img-fluid" >
            }
            else
            {
                <img src="/images/no-image.png" alt="No image available" class="food-image" >
            }
        </div>

        <!-- Right Column: Details and Add to Basket -->
        <div class="col-md-6">
            <h2>@Model.Burger.Name</h2>
            <p>@Model.Burger.Description</p>

            <p>
                @if (Model.Burger.IsVegetarian)
                {
                    <span class="badge badge-success">Vegetarian</span>
                }
                @if (Model.Burger.Special)
                {
                    <span class="badge badge-warning">Special</span>
                }
            </p>

            <h3>@Model.Burger.Price.ToString("C")</h3>

            <!-- Add to Basket Form -->
            <form method="post" asp-page-handler="Buy">
                <input type="hidden" name="Id" value="@Model.Burger.Id" >
                <input type="hidden" name="itemType" value="Burger" >

                <div class="form-group">
                    <label for="quantity">Quantity:</label>
                    <input type="number" class="form-control" id="quantity" name="quantity" value="1" min="1" max="20" >
                </div>

                <button type="submit" class="btn btn-primary">Add to Basket</button>
            </form>
        </div>
    </div>
</div>

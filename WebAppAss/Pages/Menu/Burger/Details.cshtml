@page "{id:int}"
@model WebAppAss.Pages.Menu.Burger.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Burger</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Burger.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Burger.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Burger.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Burger.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Burger.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Burger.Price)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Burger.Type)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Burger.Type)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Burger.IsVegetarian)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Burger.IsVegetarian)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Burger.IsAvailable)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Burger.IsAvailable)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Burger.Special)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Burger.Special)
        </dd>
        <dt class="col-sm-2">Image</dt>
        <dd class="col-sm-10">
            @if (Model.Burger.ImageData != null)
            {
                <img src="data:image;base64,@Convert.ToBase64String(Model.Burger.ImageData)"
                     alt="@Model.Burger.ImageDescription"
                     class="img-fluid" />
            }
            else
            {
                <span class="text-muted">No image available</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Burger?.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>

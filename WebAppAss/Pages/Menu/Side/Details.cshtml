@page "{id:int}"
@model WebAppAss.Pages.Menu.Side.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Side</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Side.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Side.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Side.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Side.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Side.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Side.Price)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Side.Size)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Side.Size)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Side.IsAvailable)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Side.IsAvailable)
        </dd>
        <dd class="col-sm-10">
            @if (Model.Side.ImageData != null)
            {
                <img src="data:image;base64,@Convert.ToBase64String(Model.Side.ImageData)"
                     alt="@Model.Side.ImageDescription"
                     class="img-fluid" />
            }
            else
            {
                <span class="text-muted">No image available</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Side?.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>

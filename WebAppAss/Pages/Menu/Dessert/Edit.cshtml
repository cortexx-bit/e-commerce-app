@page "{name}"
@model WebAppAss.Pages.Menu.Dessert.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Dessert</h4>
<hr >
<div class="row">
    <div class="col-md-4" enctype="multipart/form-data">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Dessert.Id" >
            <input type="hidden" asp-for="Dessert.ConcurrencyToken" >
            <div class="form-group">
                <label asp-for="Dessert.Name" class="control-label"></label>
                <input asp-for="Dessert.Name" class="form-control" >
                <span asp-validation-for="Dessert.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Dessert.Description" class="control-label"></label>
                <input asp-for="Dessert.Description" class="form-control" >
                <span asp-validation-for="Dessert.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Dessert.Price" class="control-label"></label>
                <input asp-for="Dessert.Price" class="form-control" >
                <span asp-validation-for="Dessert.Price" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Dessert.IsWarmDessert" > @Html.DisplayNameFor(model => model.Dessert.IsWarmDessert)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Dessert.IsAvailable" > @Html.DisplayNameFor(model => model.Dessert.IsAvailable)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="Dessert.ImageDescription" class="control-label"></label>
                <input asp-for="Dessert.ImageDescription" class="form-control" >
                <span asp-validation-for="Dessert.ImageDescription" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Dessert.ImageData" class="control-label">Image Upload</label>
                <input type="file" id="file1"
                       name="file1"
                       multiple="multiple" >
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" >
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@page "{name}"
@model WebAppAss.Pages.Menu.Dessert.DetailsModel
@{
    ViewData["Title"] = "Dessert Details";
}

<div class="container mt-5">
    <div class="row">
        <!-- Left Column: Large Image -->
        <div class="col-md-6">
            @if (Model.Dessert.ImageData != null)
            {
                <img src="data:image;base64,@Convert.ToBase64String(Model.Dessert.ImageData)"
                     alt="@Model.Dessert.ImageDescription"
                     class="img-fluid" >
            }
            else
            {
                <img src="/images/no-image.png" alt="No image available" class="img-fluid" >
            }
        </div>

        <!-- Right Column: Details and Add to Basket -->
        <div class="col-md-6">
            <h2>@Model.Dessert.Name</h2>
            <p>@Model.Dessert.Description</p>

            <p>
                @if (Model.Dessert.IsWarmDessert)
                {
                    <span class="badge badge-warning">Warm Dessert</span>
                }
                else
                {
                    <span class="badge badge-secondary">Not a Warm Dessert</span>
                }
            </p>

            <h3>@Model.Dessert.Price.ToString("C")</h3>

            <!-- Add to Basket Form -->
            <form method="post" asp-page-handler="Buy">
                <input type="hidden" name="Id" value="@Model.Dessert.Id" >
                <input type="hidden" name="itemType" value="Dessert" >

                <div class="form-group">
                    <label for="quantity">Quantity:</label>
                    <input type="number" class="form-control" id="quantity" name="quantity" value="1" min="1" max="20" >
                </div>

                <button type="submit" class="btn btn-primary">Add to Basket</button>
            </form>
        </div>
    </div>
</div>

@page "{name}"
@model WebAppAss.Pages.Menu.Drink.DetailsModel
@{
    ViewData["Title"] = "Drink Details";
}

<div class="container mt-5">
    <div class="row">
        <!-- Left Column: Large Image -->
        <div class="col-md-6">
            @if (Model.Drink.ImageData != null)
            {
                <img src="data:image;base64,@Convert.ToBase64String(Model.Drink.ImageData)"
                     alt="@Model.Drink.ImageDescription"
                     class="img-fluid" >
            }
            else
            {
                <img src="/images/no-image.png" alt="No image available" class="img-fluid" >
            }
        </div>

        <!-- Right Column: Details and Add to Basket -->
        <div class="col-md-6">
            <h2>@Model.Drink.Name</h2>
            <p>@Model.Drink.Description</p>
            <p>
                <strong>Size:</strong> @Model.Drink.Size
            </p>
            <p>
                @if (Model.Drink.IsAlcoholic)
                {
                    <span class="badge badge-danger">Alcoholic</span>
                }
                else
                {
                    <span class="badge badge-success">Non-Alcoholic</span>
                }
            </p>
            <h3>@Model.Drink.Price.ToString("C")</h3>

            <!-- Add to Basket Form -->
            <form method="post" asp-page-handler="Buy">
                <input type="hidden" name="Id" value="@Model.Drink.Id" >
                <input type="hidden" name="itemType" value="Drink" >

                <div class="form-group">
                    <label for="quantity">Quantity:</label>
                    <input type="number" class="form-control" id="quantity" name="quantity" value="1" min="1" max="20" >
                </div>

                <button type="submit" class="btn btn-primary">Add to Basket</button>
            </form>
        </div>
    </div>
</div>

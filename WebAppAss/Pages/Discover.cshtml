@page
@model DiscoverModel
@{
    ViewData["Title"] = "Discover";
}

<div class="discover-banner">
    <h1>Discover</h1>
</div>
<!-- Customer Reviews Section -->
<section class="reviews-section">
    <h2>What Our Customers Say</h2>
    <div class="reviews-grid">
        <div class="review">
            <img class="review-avatar" src="/img/avatar-1.jpg" alt="Jane Doe" />
            <div class="review-content">
                <h4>Jane Doe</h4>
                <p>"Great experience! The food was amazing and the service was top-notch."</p>
            </div>
        </div>
        <div class="review">
            <img class="review-avatar" src="/img/avatar-2.jpg" alt="John Smith" />
            <div class="review-content">
                <h4>John Smith</h4>
                <p>"I love the menu variety and the special deals. Highly recommended!"</p>
            </div>
        </div>
        <div class="review">
            <img class="review-avatar" src="/img/avatar-3.jpg" alt="Alice Johnson" />
            <div class="review-content">
                <h4>Alice Johnson</h4>
                <p>"A wonderful place to dine with friends. The ambiance is superb."</p>
            </div>
        </div>
    </div>
</section>